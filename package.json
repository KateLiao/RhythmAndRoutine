{
  "name": "rhythm-and-routine",
  "version": "0.3.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:review-followups": "tsx --test src/server/services/review-followups.test.ts",
    "test:schedule-investment": "tsx --test src/lib/schedule-investment.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:up && prisma migrate deploy && npm run db:seed",
    "repair:tasks:dry-run": "tsx scripts/repair-auto-completed-tasks.ts",
    "repair:tasks:apply": "tsx scripts/repair-auto-completed-tasks.ts --apply",
    "repair:schedule-links:dry-run": "tsx scripts/repair-schedule-task-links.ts",
    "repair:schedule-links:apply": "tsx scripts/repair-schedule-task-links.ts --apply"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "6.0.208",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.468.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.9",
    "prisma": "7.8.0",
    "tailwindcss": "4.1.18",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    },
    "postcss": "8.5.15"
  }
}
