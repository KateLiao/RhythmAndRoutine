{
  "name": "rhythm-and-routine",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:review-followups": "tsx --test src/server/services/review-followups.test.ts",
    "test:review-schedule-blocks": "tsx --test src/server/services/review-schedule-blocks.test.ts",
    "test:schedule-investment": "tsx --test src/lib/schedule-investment.test.ts",
    "test:goal-execution": "tsx --test src/server/services/goal-execution.test.ts",
    "test:execution-feedback": "tsx --test src/domain/execution-feedback.test.ts src/server/validation-execution-feedback.test.ts src/server/services/review-feedback-signals.test.ts src/components/execution-feedback-modal.test.tsx",
    "v0.4:feedback:snapshot": "tsx scripts/execution-feedback-v2-migration.ts snapshot",
    "v0.4:feedback:verify": "tsx scripts/execution-feedback-v2-migration.ts verify",
    "test:agent-quality": "tsx --test src/agent/agent-quality.test.ts src/agent/proposal-continuation.test.ts src/agent/runtime-context-budget.test.ts src/agent/schedule-planning-policy.test.ts src/agent/tool-evidence-ledger.test.ts src/server/services/change-set-decision.test.ts",
    "eval:agent": "tsx src/agent/evals/run-deterministic-evals.ts",
    "eval:agent:model-sample": "tsx src/agent/evals/run-model-router-sample.ts",
    "eval:agent:continuation-model-sample": "tsx src/agent/evals/run-continuation-model-sample.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:up && prisma migrate deploy && npm run db:seed",
    "repair:tasks:dry-run": "tsx scripts/repair-auto-completed-tasks.ts",
    "repair:tasks:apply": "tsx scripts/repair-auto-completed-tasks.ts --apply",
    "repair:schedule-links:dry-run": "tsx scripts/repair-schedule-task-links.ts",
    "repair:schedule-links:apply": "tsx scripts/repair-schedule-task-links.ts --apply",
    "v0.4:goal:snapshot": "tsx scripts/v0-4-0-goal-migration.ts snapshot",
    "v0.4:goal:verify": "tsx scripts/v0-4-0-goal-migration.ts verify",
    "v0.4:goal:verify-normalized": "tsx scripts/v0-4-0-goal-migration.ts verify-normalized",
    "v0.4:goal:apply": "tsx scripts/v0-4-0-goal-migration.ts apply",
    "v0.4:goal:backfill": "tsx scripts/v0-4-0-goal-backfill.ts",
    "v0.4:goal:backfill:apply": "tsx scripts/v0-4-0-goal-backfill.ts --apply"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "6.0.208",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.468.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.9",
    "prisma": "7.8.0",
    "tailwindcss": "4.1.18",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  },
  "overrides": {
